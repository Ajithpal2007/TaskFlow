{
  "name": "taskflow",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "tsx --watch apps/api/src/index.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.30.10",
      "react": "^18.3.1",
      "@types/react": "^18.3.1",
      "@types/react-dom": "^18.3.0"
    }
  }
}