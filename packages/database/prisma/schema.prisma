generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum ProjectRole {
  MANAGER
  CONTRIBUTOR
  VIEWER
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELED
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  EPIC
  STORY
  TASK
  BUG
  SUBTASK
}

enum DependencyType {
  BLOCKS
  IS_BLOCKED_BY
  RELATES_TO
  DUPLICATES
}

enum NotificationType {
  ASSIGNED
  MENTIONED
  COMMENT_ADDED
  STATUS_CHANGED
  SYSTEM
}

enum Visibility {
  PUBLIC // Everyone in the Workspace can see it
  PRIVATE // Only the Author can see it
  SHARED // Author + Specific invited users can see it
}

enum ChannelType {
  DIRECT // 1-on-1 private chat
  GROUP // Multi-user channel (e.g., #general)
}

enum ChannelRole {
  OWNER // Creator of the channel
  ADMIN // Can manage members and delete messages
  MEMBER // Standard participant
  GUEST // Read-only or limited access
}

enum CallType {
  HUDDLE // Ad-hoc, instant voice/video tied to a Channel or DM
  SCHEDULED // Formal, Zoom-style meeting tied to a Workspace
}

enum CallStatus {
  SCHEDULED // Future meeting, waiting to start
  ONGOING // LiveKit room is currently active
  ENDED // Call is permanently closed
  CANCELLED // Scheduled meeting was cancelled
}

enum CallRole {
  HOST // Has admin rights (mute others, kick, record)
  CO_HOST // Helper admin
  PARTICIPANT // Standard user who can share audio/video/screen
  GUEST // View-only (Webinar style)
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // App Relations
  workspaces    WorkspaceMember[]
  projects      ProjectMember[]
  createdTasks  Task[]            @relation("CreatedTasks")
  assignedTasks Task[]            @relation("AssignedTasks")
  watchedTasks  Task[]            @relation("TaskWatchers")

  comments        Comment[]
  activityLogs    ActivityLog[]
  sentInvitations WorkspaceInvitation[]

  notifications Notification[]

  documents     Document[]
  collaborators DocumentAccess[]

  channelMembers ChannelMember[]
  messages       Message[]
  reactions      Reaction[]

  hostedCalls        Call[]              @relation("CallHost")
  callParticipants   CallParticipant[]
  whiteboards        Whiteboard[]
  whiteboardVersions WhiteboardVersion[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // For URLs: taskflow.com/acme-corp
  logo      String?


  planId                 String?           // e.g., "PRO", "ENTERPRISE"
  paymentProvider        PaymentProvider?  // Tracks how they paid
  currentPeriodEnd       DateTime?         // When their access expires

  // 🟢 STRIPE FIELDS (For International)
  stripeCustomerId       String?   @unique 
  stripeSubscriptionId   String?   @unique 
  
  // 🟢 RAZORPAY FIELDS (For India/UPI)
  razorpayCustomerId     String?   @unique
  razorpaySubscriptionId String?   @unique

  // 🟢 NEW SLACK FIELDS
  slackAccessToken String?  // The token used to post messages
  slackChannelId   String?  // The specific channel they want updates in

  // 🟢 NEW ZAPIER / API FIELDS
  apiKey           String?  @unique // A secure, random string for Zapier
  zapierWebhookUrl String?

  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     WorkspaceMember[]
  projects    Project[]
  tags        Tag[] // Shared tags across the workspace
  invitations WorkspaceInvitation[]

  documents Document[]

  channels    Channel[]
  calls       Call[]
  whiteboards Whiteboard[]

  @@map("workspaces")
}

model WorkspaceMember {
  id        String        @id @default(cuid())
  role      WorkspaceRole @default(MEMBER)
  createdAt DateTime      @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

// ==========================================
// PROJECTS & ORGANIZATION
// ==========================================

model Project {
  id          String   @id @default(cuid())
  name        String
  identifier  String   @db.VarChar(10) // e.g., "ENG" for task ENG-123
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wipLimits Json? // e.g., { "TODO": 5, "IN_PROGRESS": 3 }

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  members ProjectMember[]
  tasks   Task[]

  documents Document[]

  channels    Channel[]
  whiteboards Whiteboard[]

  @@unique([workspaceId, identifier]) // Identifiers must be unique per workspace
  @@index([workspaceId])
  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(cuid())
  role      ProjectRole @default(CONTRIBUTOR)
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

// ==========================================
// CORE TASK ENGINE
// ==========================================

model Task {
  id          String       @id @default(cuid())
  sequenceId  Int // The "123" in "ENG-123". Handled by your API logic.
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(NONE)
  type        TaskType     @default(TASK)
  storyPoints Int?
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign Keys
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation("CreatedTasks", fields: [creatorId], references: [id])

  assigneeId String?
  assignee   User?   @relation("AssignedTasks", fields: [assigneeId], references: [id])

  // Hierarchical Relations (Epics -> Tasks -> Subtasks)
  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks     Task[]  @relation("Subtasks")

  // Many-to-Many & Complex Relations
  tags          Tag[]          @relation("TaskTags")
  comments      Comment[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  attachments   Attachment[]
  linkedDocs    TaskDocument[]

  // Task Dependencies (e.g., Task A blocks Task B)
  blocking  TaskDependency[] @relation("TaskBlocking")
  blockedBy TaskDependency[] @relation("TaskBlockedBy")
  watchers  User[]           @relation("TaskWatchers")

  estimatedHours Float? // The original budget
  actualHours    Float? // The reality when done

  @@unique([projectId, sequenceId]) // Ensures ENG-1, ENG-2 uniqueness
  @@index([projectId, status])
  @@index([assigneeId])
  @@map("tasks")
}

// ==========================================
// COLLABORATION & TRACKING
// ==========================================

model TaskDependency {
  id   String         @id @default(cuid())
  type DependencyType @default(BLOCKS)

  blockingId String
  blocking   Task   @relation("TaskBlocking", fields: [blockingId], references: [id], onDelete: Cascade)

  blockedById String
  blockedBy   Task   @relation("TaskBlockedBy", fields: [blockedById], references: [id], onDelete: Cascade)

  @@unique([blockingId, blockedById])
  @@map("task_dependencies")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([taskId])
  @@map("comments")
}

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#E2E8F0")

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[] @relation("TaskTags")

  @@unique([workspaceId, name])
  @@map("tags")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String // e.g., "STATUS_CHANGED", "ASSIGNEE_CHANGED"
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  @@index([taskId])
  @@map("activity_logs")
}

model WorkspaceInvitation {
  id    String @id @default(cuid())
  email String
  token String @unique
  role  String @default("MEMBER") // Could be ADMIN, MEMBER, VIEWER

  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  inviterId String
  inviter   User   @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  // Security & Timestamps
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Constraints
  @@unique([email, workspaceId]) // Prevents spamming the same email for the same workspace
  @@index([token]) // Ultra-fast lookups when they click the magic link
}

model Notification {
  id     String @id @default(cuid())
  userId String // The user receiving the notification
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String? // The task this relates to (optional)
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  type      NotificationType
  content   String // e.g., "Ajith assigned you to Task B"
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

model Attachment {
  id   String @id @default(cuid())
  name String // File name (e.g., "design-v1.png")
  url  String // The URL from UploadThing
  size String // Formatted size (e.g., "1.2MB")
  type String // File type (e.g., "image/png")

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([messageId])
  @@map("attachments")
}

// 🟢 THE CORE DOCUMENT MODEL
model Document {
  id    String @id @default(cuid())
  title String @default("Untitled")

  // 🟢 BlockNote Data Storage
  // We use Json to store the exact array of blocks BlockNote generates.
  content Json?

  // 🟢 Notion-style Metadata
  emoji      String? // e.g., "🚀"
  coverImage String? // URL to an unsplash image or uploaded file

  // 🟢 Access & State
  isArchived Boolean @default(false)
  isLocked   Boolean @default(false) // Prevents accidental edits (Read-Only mode)

  // 🟢 INFINITE NESTING (The "Notion" Superpower)
  // This allows a Document to be a "child" of another Document.
  parentId String?
  parent   Document?  @relation("DocumentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Document[] @relation("DocumentTree")

  // 🟢 Location Hierarchy
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // projectId is optional so Docs can live globally in a Workspace, OR inside a specific Project
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 🟢 Ownership
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  // 🟢 The TaskBridge
  linkedTasks TaskDocument[]

  visibility Visibility @default(PUBLIC)

  // 🟢 The relationship to track who has been invited
  collaborators DocumentAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for lightning-fast queries when opening a workspace or project
  @@index([workspaceId])
  @@index([projectId])
  @@index([parentId])
}

// 🟢 THE BI-DIRECTIONAL BRIDGE (ClickUp Superpower)
// This junction table allows many Tasks to be linked to many Documents.
model TaskDocument {
  id String @id @default(cuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Prevents linking the exact same task to the exact same doc twice
  @@unique([taskId, documentId])
  @@index([taskId])
  @@index([documentId])
}

model DocumentAccess {
  id         String @id @default(cuid())
  documentId String
  userId     String

  // E.g., "VIEW", "COMMENT", "EDIT"
  accessLevel String @default("VIEW")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only have one access record per document
  @@unique([documentId, userId])
}

// ==========================================
// REAL-TIME MESSAGING & CHAT ENGINE
// ==========================================

model Channel {
  id          String      @id @default(cuid())
  name        String? // e.g., "engineering-team" (Null for DIRECT chats)
  description String?     @db.Text
  type        ChannelType @default(DIRECT)
  isPrivate   Boolean     @default(false) // RBAC: If true, only invited members can see it

  // Location
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Optional: A channel dedicated specifically to a single Project
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  members  ChannelMember[]
  messages Message[]
  calls    Call[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([projectId])
  @@map("channels")
}

model ChannelMember {
  id   String      @id @default(cuid())
  role ChannelRole @default(MEMBER) // RBAC within the specific channel

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // For Unread Notifications
  lastReadAt DateTime @default(now())
  joinedAt   DateTime @default(now())

  @@unique([userId, channelId]) // A user is only in a channel once
  @@index([channelId])
  @@map("channel_members")
}

model Message {
  id      String @id @default(cuid())
  content String @db.Text

  // Enterprise States
  isEdited  Boolean   @default(false)
  deletedAt DateTime? // Soft-delete: We hide the message but keep the record for compliance

  // Relations
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  // 🟢 THREADS (Self-Relation)
  // A message can be a reply to a parent message
  parentId String?
  parent   Message?  @relation("ThreadReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Message[] @relation("ThreadReplies")

  // Features
  attachments Attachment[]
  reactions   Reaction[]
  fileUrls    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId])
  @@index([senderId])
  @@index([parentId]) // Fast lookups for thread expansion
  @@map("messages")
}

// 🟢 SLACK-STYLE REACTIONS (e.g., 👍, 👀, 🚀)
model Reaction {
  id    String @id @default(cuid())
  emoji String // Stores the unicode emoji or identifier

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji]) // A user can only leave one specific emoji per message
  @@map("reactions")
}

model Call {
  id              String @id @default(cuid())
  livekitRoomName String @unique // The exact string ID used to create the LiveKit room

  type   CallType
  status CallStatus @default(ONGOING)

  // Formal Meeting Metadata (Null for Huddles)
  title       String? // e.g., "Q3 Sprint Planning"
  description String? @db.Text

  // Timing & Lifecycle
  scheduledFor DateTime? // Only populated for SCHEDULED calls
  startedAt    DateTime? // Timestamp when the first person joins
  endedAt      DateTime? // Timestamp when the room is officially destroyed

  // Relations: Where does this call live?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  channelId String? // Populated if it's an ad-hoc Huddle inside a specific channel
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // The creator/owner of the call
  hostId String
  host   User   @relation("CallHost", fields: [hostId], references: [id])

  // Connected Data
  participants CallParticipant[]
  recordings   CallRecording[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for high-performance querying
  @@index([workspaceId])
  @@index([channelId])
  @@index([status])
}

model CallParticipant {
  id String @id @default(cuid())

  callId String
  call   Call   @relation(fields: [callId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role CallRole @default(PARTICIPANT)

  // Audit trail for analytics (How long were they in the meeting?)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@unique([callId, userId]) // A user has only one participant record per call
  @@index([userId])
}

// Phase 3 Future-Proofing: Cloud Recordings
model CallRecording {
  id String @id @default(cuid())

  callId String
  call   Call   @relation(fields: [callId], references: [id], onDelete: Cascade)

  fileUrl   String // The UploadThing or S3 URL
  duration  Int? // Duration in seconds
  sizeBytes BigInt?

  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// PHASE 4: COLLABORATIVE CANVAS (TLDRAW)
// -----------------------------------------------------------------------------

model Whiteboard {
  id    String @id @default(cuid())
  title String

  // 🟢 ROUTING & MULTIPLAYER
  workspaceId String
  projectId   String? // Optional: Canvas can be workspace-wide or project-specific
  roomId      String  @unique // The exact Liveblocks/Yjs Room ID

  imageUrl String?

  // 🟢 STORAGE & RECOVERY
  // Stores the serialized tldraw document state. Used as a fallback if 
  // the Liveblocks room is hibernated or deleted.
  latestSnapshot Json?

  // 🟢 ACCESS CONTROL
  isPublic Boolean @default(false)
  isLocked Boolean @default(false) // Prevents further edits

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  // 🟢 RELATIONS
  versions WhiteboardVersion[]
  assets   WhiteboardAsset[]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([projectId])
}

// 🟢 AUDIT TRAIL & TIME-TRAVEL
// Periodically saves the canvas state (e.g., via a CRON job or manual "Save Version" button)
// so users can restore deleted ideas.
model WhiteboardVersion {
  id           String @id @default(cuid())
  whiteboardId String

  versionName String? // e.g., "Initial Brainstorm", "Pre-Design Review"
  snapshot    Json // The exact tldraw state at this moment in time

  createdAt DateTime @default(now())
  savedById String

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)
  savedBy    User       @relation(fields: [savedById], references: [id])

  @@index([whiteboardId])
}

// 🟢 ASSET MANAGEMENT (CRITICAL FOR S3/UPLOADTHING)
// Tracks images/videos pasted into the whiteboard. 
// If a whiteboard is deleted, you use this table to delete the files from your bucket.
model WhiteboardAsset {
  id           String @id @default(cuid())
  whiteboardId String

  tldrawAssetId String // The internal ID tldraw uses for this asset
  mimeType      String // e.g., "image/png", "video/mp4"
  fileUrl       String // The UploadThing / S3 URL
  fileSize      Int // Stored in bytes for billing/quota tracking

  createdAt DateTime @default(now())

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@index([whiteboardId])
}
